<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>B2B Lead Finder</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Fraunces:ital,wght@0,300;0,600;1,300&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink: #0f0e0d;
    --ink-muted: #6b6760;
    --ink-faint: #b5b2ad;
    --paper: #f5f2ed;
    --paper-warm: #ede9e2;
    --paper-card: #faf8f5;
    --accent: #c8471a;
    --accent-light: #f2e8e3;
    --green: #2d6a4f;
    --green-light: #e3f0eb;
    --border: #ddd9d3;
    --shadow: 0 1px 3px rgba(15,14,13,0.08), 0 4px 16px rgba(15,14,13,0.04);
  }

  body {
    font-family: 'DM Mono', monospace;
    background: var(--paper);
    color: var(--ink);
    min-height: 100vh;
    padding: 0;
  }

  /* Header */
  header {
    background: var(--ink);
    padding: 20px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    font-family: 'Fraunces', serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--paper);
    letter-spacing: -0.5px;
  }

  .logo span {
    color: #e87a50;
  }

  .header-tag {
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Main layout */
  main {
    max-width: 900px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .hero {
    margin-bottom: 40px;
  }

  .hero h1 {
    font-family: 'Fraunces', serif;
    font-size: 42px;
    font-weight: 300;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--accent);
  }

  .hero p {
    font-size: 13px;
    color: var(--ink-muted);
    line-height: 1.6;
  }

  /* Input area */
  .input-section {
    background: var(--paper-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    margin-bottom: 32px;
    box-shadow: var(--shadow);
  }

  .input-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  label {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  input[type="text"] {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    padding: 10px 14px;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--paper);
    color: var(--ink);
    outline: none;
    transition: border-color 0.15s;
  }

  input[type="text"]:focus {
    border-color: var(--accent);
  }

  input[type="text"]::placeholder {
    color: var(--ink-faint);
  }

  /* Bulk input */
  .bulk-toggle {
    font-size: 12px;
    color: var(--accent);
    cursor: pointer;
    text-decoration: underline;
    margin-bottom: 12px;
    display: inline-block;
    background: none;
    border: none;
    font-family: 'DM Mono', monospace;
  }

  textarea {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    padding: 12px 14px;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--paper);
    color: var(--ink);
    outline: none;
    resize: vertical;
    min-height: 100px;
    width: 100%;
    transition: border-color 0.15s;
    margin-bottom: 16px;
  }

  textarea:focus { border-color: var(--accent); }

  /* Search button */
  .btn-search {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    padding: 12px 28px;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background 0.15s, transform 0.1s;
  }

  .btn-search:hover { background: #a83915; }
  .btn-search:active { transform: scale(0.98); }
  .btn-search:disabled { background: var(--ink-faint); cursor: not-allowed; }

  /* Status bar */
  .status-bar {
    display: none;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: var(--paper-warm);
    border: 1px solid var(--border);
    border-radius: 6px 6px 0 0;
    border-bottom: none;
    font-size: 12px;
    color: var(--ink-muted);
  }

  .status-bar.visible { display: flex; }

  .spinner {
    width: 14px;
    height: 14px;
    border: 2px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    flex-shrink: 0;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  /* Log panel */
  .log-panel {
    display: none;
    flex-direction: column;
    background: #1a1916;
    border: 1px solid var(--border);
    border-radius: 0 0 6px 6px;
    margin-bottom: 24px;
    overflow: hidden;
  }

  .log-panel.visible { display: flex; }

  .log-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 14px;
    background: #111110;
    border-bottom: 1px solid #2a2926;
  }

  .log-panel-title {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #666360;
  }

  .log-clear {
    font-size: 10px;
    color: #555250;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'DM Mono', monospace;
    padding: 0;
  }
  .log-clear:hover { color: #888580; }

  .log-entries {
    padding: 10px 14px;
    max-height: 180px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .log-entry {
    display: flex;
    gap: 10px;
    align-items: baseline;
    animation: fadeIn 0.15s ease;
  }

  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .log-time {
    font-size: 10px;
    color: #444240;
    flex-shrink: 0;
    width: 52px;
  }

  .log-msg {
    font-size: 11px;
    line-height: 1.5;
  }

  .log-entry.info .log-msg { color: #8b9eaa; }
  .log-entry.search .log-msg { color: #a0b87a; }
  .log-entry.success .log-msg { color: #7db88a; }
  .log-entry.warn .log-msg { color: #c9a95a; }
  .log-entry.error .log-msg { color: #c97a6a; }

  /* Results */
  .results-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .results-count {
    font-size: 12px;
    color: var(--ink-muted);
  }

  .btn-export {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    padding: 8px 18px;
    background: var(--green-light);
    color: var(--green);
    border: 1px solid #b7d9c8;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: background 0.15s;
  }

  .btn-export:hover { background: #d0eadf; }

  /* Lead cards */
  .leads-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .lead-card {
    background: var(--paper-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px 24px;
    box-shadow: var(--shadow);
    animation: fadeUp 0.3s ease forwards;
    opacity: 0;
  }

  /* Contacts section */
  .contacts-section {
    margin-top: 16px;
    border-top: 1px solid var(--border);
    padding-top: 14px;
  }

  .contacts-label {
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 10px;
  }

  .contacts-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr auto;
    gap: 12px;
    align-items: center;
    padding: 10px 14px;
    background: var(--paper-warm);
    border-radius: 6px;
    border: 1px solid var(--border);
  }

  .contact-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
  }

  .contact-role {
    font-size: 11px;
    color: var(--ink-muted);
  }

  .contact-detail {
    font-size: 12px;
    color: var(--ink-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .contact-detail a {
    color: var(--accent);
    text-decoration: none;
  }

  .contact-detail a:hover { text-decoration: underline; }

  .contact-source {
    font-size: 10px;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .no-contacts {
    font-size: 12px;
    color: var(--ink-faint);
    font-style: italic;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .lead-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .lead-name {
    font-family: 'Fraunces', serif;
    font-size: 20px;
    font-weight: 600;
    color: var(--ink);
  }

  .lead-website {
    font-size: 12px;
    color: var(--accent);
    text-decoration: none;
  }

  .lead-website:hover { text-decoration: underline; }

  .confidence-badge {
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 20px;
    font-weight: 500;
  }

  .confidence-high { background: var(--green-light); color: var(--green); }
  .confidence-med { background: #fef3e2; color: #9a6700; }
  .confidence-low { background: var(--accent-light); color: var(--accent); }

  .lead-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 10px;
    margin-bottom: 12px;
  }

  .lead-field {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .field-label {
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .field-value {
    font-size: 13px;
    color: var(--ink);
  }

  .field-value.missing {
    color: var(--ink-faint);
    font-style: italic;
  }

  .lead-description {
    font-size: 12px;
    color: var(--ink-muted);
    line-height: 1.6;
    border-top: 1px solid var(--border);
    padding-top: 10px;
  }

  /* Error */
  .error-msg {
    background: var(--accent-light);
    border: 1px solid #e8c5b8;
    border-radius: 6px;
    padding: 14px 18px;
    font-size: 13px;
    color: var(--accent);
    margin-bottom: 16px;
    display: none;
  }

  .error-msg.visible { display: block; }

  /* Empty state */
  .empty {
    text-align: center;
    padding: 60px 20px;
    color: var(--ink-faint);
    font-size: 13px;
    line-height: 1.8;
  }

  .empty-icon {
    font-size: 40px;
    margin-bottom: 12px;
    display: block;
    opacity: 0.4;
  }

  @media (max-width: 600px) {
    .input-row { grid-template-columns: 1fr; }
    header { padding: 16px 20px; }
    main { padding: 32px 16px 60px; }
    .hero h1 { font-size: 30px; }
  }
</style>
</head>
<body>

<header>
  <div class="logo">lead<span>finder</span></div>
  <span class="header-tag">B2B · AI-powered</span>
</header>

<main>
  <div class="hero">
    <h1>Find leads,<br><em>intelligently.</em></h1>
    <p>Enter a company name or website URL. Claude searches the web and extracts structured B2B lead data.</p>
  </div>

  <div class="input-section">
    <div class="input-row" id="single-row">
      <div class="field">
        <label>Company name</label>
        <input type="text" id="company-name" placeholder="e.g. Atlassian" />
      </div>
      <div class="field">
        <label>Website URL (optional)</label>
        <input type="text" id="company-url" placeholder="e.g. atlassian.com" />
      </div>
    </div>

    <button class="bulk-toggle" id="bulk-toggle-btn" onclick="toggleBulk()">+ Add multiple companies at once</button>

    <div id="bulk-area" style="display:none;">
      <textarea id="bulk-input" placeholder="One company per line:&#10;Atlassian&#10;monday.com&#10;Notion&#10;Linear"></textarea>
    </div>

    <button class="btn-search" id="search-btn" onclick="runSearch()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      Research leads
    </button>
  </div>

  <div class="status-bar" id="status-bar">
    <div class="spinner"></div>
    <span id="status-text">Searching the web...</span>
  </div>

  <div class="log-panel" id="log-panel">
    <div class="log-panel-header">
      <span class="log-panel-title">Activity log</span>
      <button class="log-clear" onclick="clearLog()">clear</button>
    </div>
    <div class="log-entries" id="log-entries"></div>
  </div>

  <div class="error-msg" id="error-msg"></div>

  <div id="results-section" style="display:none;">
    <div class="results-header">
      <span class="results-count" id="results-count"></span>
      <button class="btn-export" onclick="exportCSV()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Export CSV
      </button>
    </div>
    <div class="leads-grid" id="leads-grid"></div>
  </div>

  <div class="empty" id="empty-state">
    <span class="empty-icon">◎</span>
    Enter a company name above to begin.<br>Results appear here with structured data<br>ready to export.
  </div>
</main>

<script>
let allLeads = [];
let bulkMode = false;
let logStart = null;

function toggleBulk() {
  bulkMode = !bulkMode;
  document.getElementById('bulk-area').style.display = bulkMode ? 'block' : 'none';
  document.getElementById('single-row').style.display = bulkMode ? 'none' : 'grid';
  document.getElementById('bulk-toggle-btn').textContent = bulkMode ? '− Single company' : '+ Add multiple companies at once';
}

function addLog(msg, type = 'info') {
  const panel = document.getElementById('log-panel');
  const entries = document.getElementById('log-entries');
  panel.classList.add('visible');
  const elapsed = logStart ? ((Date.now() - logStart) / 1000).toFixed(1) + 's' : '0.0s';
  const row = document.createElement('div');
  row.className = `log-entry ${type}`;
  row.innerHTML = `<span class="log-time">${elapsed}</span><span class="log-msg">${msg}</span>`;
  entries.appendChild(row);
  entries.scrollTop = entries.scrollHeight;
}

function clearLog() {
  document.getElementById('log-entries').innerHTML = '';
}

function setStatus(msg) {
  const bar = document.getElementById('status-bar');
  bar.classList.add('visible');
  document.getElementById('status-text').textContent = msg;
}

function hideStatus() {
  document.getElementById('status-bar').classList.remove('visible');
}

function showError(msg) {
  const el = document.getElementById('error-msg');
  el.textContent = msg;
  el.classList.add('visible');
}

function hideError() {
  document.getElementById('error-msg').classList.remove('visible');
}

async function researchCompany(name, url) {
  addLog(`Starting research for "${name}"…`, 'info');

  const response = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 2000,
      tools: [{ type: "web_search_20250305", name: "web_search" }],
      messages: [{ role: "user", content: prompt(name, url) }]
    })
  });

  addLog(`API request sent — waiting for response…`, 'search');

  if (!response.ok) {
    addLog(`API error: ${response.status} ${response.statusText}`, 'error');
    throw new Error(`API error: ${response.status}`);
  }

  const data = await response.json();
  addLog(`Response received — extracting data…`, 'search');

  const searchCalls = data.content.filter(b => b.type === 'tool_use' && b.name === 'web_search');
  if (searchCalls.length) {
    searchCalls.forEach(s => addLog(`↳ Web search: "${s.input?.query || '...'}"`, 'search'));
  }

  const textBlocks = data.content.filter(b => b.type === 'text');
  const raw = textBlocks.map(b => b.text).join('');

  const jsonMatch = raw.match(/\{[\s\S]*\}/);
  if (!jsonMatch) {
    addLog(`Could not parse structured data from response`, 'error');
    throw new Error('Could not parse response');
  }

  const parsed = JSON.parse(jsonMatch[0]);
  const contactCount = Array.isArray(parsed.contacts) ? parsed.contacts.filter(c => c.name).length : 0;
  addLog(`✓ "${parsed.company_name || name}" — ${contactCount} contact${contactCount !== 1 ? 's' : ''} found (${parsed.confidence || 'medium'} confidence)`, 'success');
  return parsed;
}

function prompt(name, url) {
  return `Research the company "${name}"${url ? ` (website: ${url})` : ''} and return structured B2B lead data including key contacts.

Use web search to find accurate, current information. Search for:
1. General company info (website, industry, size, location, founding year)
2. Key decision-makers and their publicly available contact details (name, title, email, phone, LinkedIn)

Return ONLY a valid JSON object with these exact fields (no markdown, no code fences, no explanation):

{
  "company_name": "Official company name",
  "website": "company website URL",
  "industry": "industry/sector",
  "company_size": "employee count or range e.g. 50-200 or 10,000+",
  "location": "HQ city, country",
  "founded": "founding year",
  "description": "2 sentence description of what the company does",
  "linkedin": "LinkedIn company page URL if known",
  "phone": "main company phone if publicly available, else null",
  "email_pattern": "common email format e.g. firstname@company.com if inferable",
  "confidence": "high / medium / low based on how much verified info you found",
  "contacts": [
    {
      "name": "Full name",
      "title": "Job title",
      "email": "email address if publicly available, else null",
      "phone": "direct phone if publicly available, else null",
      "linkedin": "personal LinkedIn URL if found, else null",
      "source": "where you found this info e.g. company website, LinkedIn, press release"
    }
  ]
}

For contacts: include up to 3 key decision-makers (CEO, founders, heads of sales/marketing/operations). Only include contacts where you found at least their name and title. Use null for any contact fields you cannot verify. Do not invent any data.`;
}

async function runSearch() {
  hideError();
  allLeads = [];
  logStart = Date.now();
  clearLog();

  let companies = [];

  if (bulkMode) {
    const lines = document.getElementById('bulk-input').value.trim().split('\n').filter(l => l.trim());
    if (!lines.length) { showError('Please enter at least one company name.'); return; }
    companies = lines.map(l => ({ name: l.trim(), url: '' }));
  } else {
    const name = document.getElementById('company-name').value.trim();
    const url = document.getElementById('company-url').value.trim();
    if (!name && !url) { showError('Please enter a company name or website.'); return; }
    companies = [{ name: name || url, url }];
  }

  addLog(`Search started — ${companies.length} compan${companies.length !== 1 ? 'ies' : 'y'} queued`, 'info');

  const btn = document.getElementById('search-btn');
  btn.disabled = true;
  document.getElementById('results-section').style.display = 'none';
  document.getElementById('empty-state').style.display = 'none';
  document.getElementById('leads-grid').innerHTML = '';

  for (let i = 0; i < companies.length; i++) {
    const { name, url } = companies[i];
    setStatus(`Researching ${name}… (${i + 1} of ${companies.length})`);
    try {
      const lead = await researchCompany(name, url);
      allLeads.push(lead);
      renderLead(lead, i);
      document.getElementById('results-section').style.display = 'block';
      document.getElementById('results-count').textContent = `${allLeads.length} lead${allLeads.length !== 1 ? 's' : ''} found`;
    } catch (e) {
      addLog(`Error researching "${name}": ${e.message}`, 'error');
      showError(`Error researching "${name}": ${e.message}`);
    }
  }

  const total = ((Date.now() - logStart) / 1000).toFixed(1);
  addLog(`Done — ${allLeads.length} lead${allLeads.length !== 1 ? 's' : ''} returned in ${total}s`, 'success');
  hideStatus();
  btn.disabled = false;

  if (!allLeads.length) {
    document.getElementById('empty-state').style.display = 'block';
  }
}

function renderLead(lead, idx) {
  const grid = document.getElementById('leads-grid');
  const conf = lead.confidence || 'medium';
  const confClass = conf === 'high' ? 'confidence-high' : conf === 'low' ? 'confidence-low' : 'confidence-med';
  const confLabel = conf.charAt(0).toUpperCase() + conf.slice(1) + ' confidence';

  const v = (val, fallback = '—') => val && val !== 'null' ? val : `<span class="missing">${fallback}</span>`;

  // Build contacts HTML
  const contacts = Array.isArray(lead.contacts) ? lead.contacts.filter(c => c.name) : [];
  let contactsHTML = '';
  if (contacts.length) {
    const rows = contacts.map(c => `
      <div class="contact-row">
        <div>
          <div class="contact-name">${c.name || '—'}</div>
          <div class="contact-role">${c.title || '—'}</div>
        </div>
        <div class="contact-detail">${c.email ? `<a href="mailto:${c.email}">${c.email}</a>` : '<span style="color:var(--ink-faint)">No email found</span>'}</div>
        <div class="contact-detail">${c.phone || '<span style="color:var(--ink-faint)">No phone found</span>'}</div>
        <div class="contact-source">${c.source ? `via ${c.source}` : ''}</div>
      </div>
    `).join('');
    contactsHTML = `
      <div class="contacts-section">
        <div class="contacts-label">Key contacts (${contacts.length})</div>
        <div class="contacts-list">${rows}</div>
      </div>`;
  } else {
    contactsHTML = `
      <div class="contacts-section">
        <div class="contacts-label">Key contacts</div>
        <div class="no-contacts">No publicly available contacts found</div>
      </div>`;
  }

  const card = document.createElement('div');
  card.className = 'lead-card';
  card.style.animationDelay = `${idx * 80}ms`;
  card.innerHTML = `
    <div class="lead-top">
      <div>
        <div class="lead-name">${lead.company_name || 'Unknown Company'}</div>
        ${lead.website ? `<a class="lead-website" href="${lead.website.startsWith('http') ? lead.website : 'https://' + lead.website}" target="_blank">${lead.website}</a>` : ''}
      </div>
      <span class="confidence-badge ${confClass}">${confLabel}</span>
    </div>
    <div class="lead-grid">
      <div class="lead-field"><span class="field-label">Industry</span><span class="field-value">${v(lead.industry)}</span></div>
      <div class="lead-field"><span class="field-label">Company size</span><span class="field-value">${v(lead.company_size)}</span></div>
      <div class="lead-field"><span class="field-label">Location</span><span class="field-value">${v(lead.location)}</span></div>
      <div class="lead-field"><span class="field-label">Founded</span><span class="field-value">${v(lead.founded)}</span></div>
      <div class="lead-field"><span class="field-label">Email pattern</span><span class="field-value">${v(lead.email_pattern)}</span></div>
      <div class="lead-field"><span class="field-label">Phone</span><span class="field-value">${v(lead.phone)}</span></div>
      <div class="lead-field"><span class="field-label">LinkedIn</span><span class="field-value">${lead.linkedin ? `<a class="lead-website" href="${lead.linkedin}" target="_blank">View page</a>` : '<span class="missing">—</span>'}</span></div>
    </div>
    ${lead.description ? `<div class="lead-description">${lead.description}</div>` : ''}
    ${contactsHTML}
  `;
  grid.appendChild(card);
}

function exportCSV() {
  if (!allLeads.length) return;

  const companyHeaders = ['company_name','website','industry','company_size','location','founded','email_pattern','phone','linkedin','description','confidence'];
  const contactHeaders = ['contact_name','contact_title','contact_email','contact_phone','contact_linkedin','contact_source'];
  const allHeaders = [...companyHeaders, ...contactHeaders];

  const rows = [];
  for (const lead of allLeads) {
    const companyVals = companyHeaders.map(h => `"${String(lead[h] || '').replace(/"/g, '""')}"`);
    const contacts = Array.isArray(lead.contacts) ? lead.contacts.filter(c => c.name) : [];
    if (contacts.length) {
      for (const c of contacts) {
        const contactVals = [
          c.name || '', c.title || '', c.email || '', c.phone || '', c.linkedin || '', c.source || ''
        ].map(v => `"${String(v).replace(/"/g, '""')}"`);
        rows.push([...companyVals, ...contactVals].join(','));
      }
    } else {
      rows.push([...companyVals, '""','""','""','""','""','""'].join(','));
    }
  }

  const csv = [allHeaders.join(','), ...rows].join('\n');
  const blob = new Blob([csv], { type: 'text/csv' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `leads_${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
  URL.revokeObjectURL(url);
}

// Enter key support
document.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey && document.activeElement.tagName !== 'TEXTAREA') runSearch();
});
